# ── Google Cloud ────────────────────────────────────────────────────────────
# Authentication uses Application Default Credentials (ADC).
# ADC resolution order:
#   1. GOOGLE_APPLICATION_CREDENTIALS — path to a service account JSON or
#      external-credentials file (optional; leave unset to skip)
#   2. gcloud user credentials: run `gcloud auth application-default login`
#   3. Workload Identity / metadata server (GCE, GKE, Cloud Run, etc.)
#
# Uncomment and set only if you need to override the default ADC source:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# GCP project to bill queries against.
# If omitted, the project detected from ADC is used.
GCP_PROJECT_ID=your-gcp-project-id

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@example.com
# For Gmail, generate an App Password at https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your-app-password
